# Setup wizard password — protects the /setup page on your Railway URL
# Set this to something strong before deploying
SETUP_PASSWORD=

# OpenClaw state directories (use Railway volume mounted at /data)
OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace

# LLM API Keys (configured via setup wizard, but listed here for reference)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Telegram (configured via setup wizard)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Travel Researcher
# Alert fires when per-adult fare drops below this (AUD)
FLIGHT_BUDGET_PER_PERSON=1600
FLIGHT_CURRENCY=AUD

# Grocery Planner
# Name/location of the supermarket to check for specials
GROCERY_STORE=Woolworths Sydney
# Household dietary preferences
GROCERY_PREFERENCES=family of 2 adults 1 child age 8, no restrictions
# Cron schedule for grocery runs (default: Sunday 9am AEST = Saturday 23:00 UTC)
GROCERY_SCHEDULE=0 23 * * 6
